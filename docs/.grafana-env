# Quick Reference — Dashboards Grafana
# 
# Salve este arquivo como .env ou use diretamente no terminal:
#   source docs/.grafana-env
#   make obs-up
#   GRAFANA_TOKEN=$GRAFANA_ADMIN_TOKEN make import-dashboards

# ── URLs Base ──────────────────────────────────────────────────────────

GRAFANA_URL="http://localhost:3000"
PROMETHEUS_URL="http://localhost:9090"

# ── Credenciais Padrão (Docker Compose) ────────────────────────────────

# Grafana admin user (padrão em docker-compose)
GRAFANA_ADMIN_USER="admin"
GRAFANA_ADMIN_PASSWORD="admin"

# ── Targets Make ──────────────────────────────────────────────────────

# Validar dashboard JSON
#   $ make validate-dashboard-security

# Validar alertas YAML
#   $ make validate-alerts-security

# Iniciar stack Prometheus + Grafana
#   $ make obs-up

# Parar stack
#   $ make obs-down

# Ver logs
#   $ make obs-logs

# Importar dashboards (requer GRAFANA_TOKEN)
#   $ GRAFANA_TOKEN=<seu_token> make import-dashboards

# ── Dashboards ────────────────────────────────────────────────────────

# Dashboard Security & Behavior (uid=orbit-security-v1)
DASHBOARD_SECURITY="deploy/grafana-dashboard-security.json"

# Dashboard Product Command Center (uid=orbit-engine-command-center)
DASHBOARD_MAIN="deploy/grafana-dashboard.json"

# ── Regras de Alerta ────────────────────────────────────────────────────

# Arquivo de alertas Prometheus (6 regras)
ALERTS_FILE="deploy/prometheus-alerts-security.yml"

# ── PromQL Quick Queries ───────────────────────────────────────────────

# Current security mode (0=normal, 1=elevated, 2=lockdown)
QUERY_MODE="sum(orbit_security_mode{mode=\"elevated\"}) * 1 + sum(orbit_security_mode{mode=\"lockdown\"}) * 2"

# Abuse ratio current
QUERY_ABUSE="orbit_behavior_abuse_ratio"

# Rejections rate (5 min)
QUERY_REJECTIONS="rate(orbit_tracking_rejected_total[5m])"

# Mode transitions (5 min)
QUERY_TRANSITIONS="rate(orbit_security_mode_transitions_total[5m])"

# Real usage alive
QUERY_ALIVE="orbit_real_usage_alive"
