# ============================================================
# orbit-engine: .gitignore
# Protege contra commit acidental de lógica interna/proprietária
# ============================================================

# --- Artefatos internos (NUNCA devem ir para repo público) ---
.internal/
.internal.*
decision-engine/
evals/
future/

# --- Arquivos de skill compilados (binários) ---
*.skill
# Skill oficial do orbit-engine é versionada
!.claude/skills/orbit-engine.skill

# --- Nomes legados do projeto ---
token-optimizer*

# --- Documentos internos que podem ser criados localmente ---
RESUMO-EXECUTIVO*
ANTI-LEAK*
FREE-FIRST*
HEURISTIC-ACTIVATION*
OUTPUT-TEMPLATES*
REPO-SEPARATION*
PHASED-EXECUTION*
cli-notes*

# --- Eval data ---
**/evals.json
**/first-run-guarantee.json

# --- OS artifacts ---
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# --- Python bytecode ---
__pycache__/
*.pyc
*.pyo

# --- Editor ---
.vscode/
.idea/
*.code-workspace

# --- Node (caso usado no futuro) ---
node_modules/
package-lock.json
yarn.lock

# --- SSH credentials and keys (NEVER commit) ---
*.pem
*.key
*.pub
id_rsa
id_ed25519
ssh_config
.ssh/
deploy/ssh_config          # rendered config (contains host/user)

# --- Logs ---
*.log

# --- Python bytecode ---
__pycache__/
*.pyc
*.pyo

# --- Evolution artifacts (local state) ---
tests/.baseline.json
tests/evidence_log.jsonl
*.bak

# --- Compiled Go binaries (must NEVER be committed) ---
# The `orbit` CLI is produced by scripts/build_orbit.sh.
# Each build changes 13MB of bytes; tracking it pollutes git history
# and breaks every merge. Rebuild locally instead.
tracking/orbit

# --- Claude Code local state (per-machine, not shareable) ---
.claude/settings.local.json
.claude/worktrees/
gate_report.json

# Go binaries compiled locally (never commit — caught by repo_hygiene_test.go)
tracking/main
tracking/orbit-gateway
tracking/tracking-server
tracking/tracking-server-*
tracking/validate_env
tracking/validate_gov
tracking/validate
tracking/validate_promql
