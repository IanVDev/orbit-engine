# ============================================================
# orbit-engine: .gitignore
# Protege contra commit acidental de lógica interna/proprietária
# ============================================================

# --- Artefatos internos (NUNCA devem ir para repo público) ---
.internal/
.internal.*
decision-engine/
evals/
future/

# --- Arquivos de skill compilados (binários) ---
*.skill
# Skill oficial do orbit-engine é versionada
!.claude/skills/orbit-engine.skill

# --- Nomes legados do projeto ---
token-optimizer*

# --- Documentos internos que podem ser criados localmente ---
RESUMO-EXECUTIVO*
ANTI-LEAK*
FREE-FIRST*
HEURISTIC-ACTIVATION*
OUTPUT-TEMPLATES*
REPO-SEPARATION*
PHASED-EXECUTION*
cli-notes*

# --- Eval data ---
**/evals.json
**/first-run-guarantee.json

# --- OS artifacts ---
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# --- Python bytecode ---
__pycache__/
*.pyc
*.pyo

# --- Editor ---
.vscode/
.idea/
*.code-workspace

# --- Node (caso usado no futuro) ---
node_modules/
package-lock.json
yarn.lock

# --- SSH credentials and keys (NEVER commit) ---
*.pem
*.key
*.pub
id_rsa
id_ed25519
ssh_config
.ssh/
deploy/ssh_config          # rendered config (contains host/user)

# --- Logs ---
*.log

# --- Evolution artifacts (local state) ---
tests/.baseline.json
tests/evidence_log.jsonl
*.bak
