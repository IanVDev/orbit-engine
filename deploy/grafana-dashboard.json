{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource (localhost:9090)",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "orbit-engine — Product Command Center. Leitura em 10 segundos: sistema vivo? gerando valor? algum risco?",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "⚡ Sistema — Vivo?",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "from": 0.01, "to": 999, "result": { "color": "green", "text": "ALIVE" } }, "type": "range" },
            { "options": { "from": 0, "to": 0, "result": { "color": "red", "text": "DEAD" } }, "type": "range" }
          ],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 0.01 }
          ] },
          "unit": "none", "noValue": "DEAD"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background", "graphMode": "none", "justifyMode": "center",
        "orientation": "auto", "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "max(up{job=\"orbit-engine-tracking\"})",
        "legendFormat": "", "refId": "A"
      }],
      "title": "💓 Heartbeat",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "1": { "color": "green", "index": 0, "text": "UP" } }, "type": "value" },
            { "options": { "0": { "color": "red", "index": 1, "text": "DOWN" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ] },
          "unit": "none", "noValue": "DOWN"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background", "graphMode": "none", "justifyMode": "center",
        "orientation": "auto", "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "orbit_tracking_up",
        "legendFormat": "", "refId": "A"
      }],
      "title": "🟢 Tracking Server",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "1": { "color": "green", "index": 0, "text": "RECEIVING" } }, "type": "value" },
            { "options": { "0": { "color": "orange", "index": 1, "text": "NO DATA" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "orange", "value": null },
            { "color": "green", "value": 1 }
          ] },
          "unit": "none", "noValue": "NO DATA"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "background", "graphMode": "none", "justifyMode": "center",
        "orientation": "auto", "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "orbit_real_usage_alive or vector(0)",
        "legendFormat": "", "refId": "A"
      }],
      "title": "📡 Real Usage",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 120 },
            { "color": "orange", "value": 300 },
            { "color": "red", "value": 600 }
          ] },
          "unit": "s", "noValue": "N/A"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "background", "graphMode": "area", "justifyMode": "center",
        "orientation": "auto", "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "orbit:event_staleness_seconds:prod or vector(0)",
        "legendFormat": "staleness", "refId": "A"
      }],
      "title": "⏱️ Último Evento",
      "type": "stat"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 200,
      "title": "💰 Valor — Sistema Gerando Resultado?",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "dark-red", "value": null },
            { "color": "orange", "value": 100 },
            { "color": "yellow", "value": 1000 },
            { "color": "green", "value": 5000 }
          ] },
          "unit": "short", "noValue": "0"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 6 },
      "id": 10,
      "options": {
        "colorMode": "background", "graphMode": "area", "justifyMode": "center",
        "orientation": "auto", "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "orbit:tokens_saved_total:prod or vector(0)",
        "legendFormat": "tokens saved", "refId": "A"
      }],
      "title": "🪙 Tokens Economizados (total)",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "orange", "value": 10 },
            { "color": "yellow", "value": 30 },
            { "color": "green", "value": 50 }
          ] },
          "unit": "percent", "min": 0, "max": 100, "noValue": "—"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 6 },
      "id": 11,
      "options": {
        "colorMode": "background", "graphMode": "area", "justifyMode": "center",
        "orientation": "auto", "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "orbit:activation_rate or vector(0)",
        "legendFormat": "activation rate", "refId": "A"
      }],
      "title": "🎯 Activation Rate",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "dark-red", "value": null },
            { "color": "orange", "value": 5 },
            { "color": "yellow", "value": 20 },
            { "color": "green", "value": 50 }
          ] },
          "unit": "short", "decimals": 1, "noValue": "—"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 6 },
      "id": 12,
      "options": {
        "colorMode": "background", "graphMode": "area", "justifyMode": "center",
        "orientation": "auto", "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "orbit:tokens_per_session or vector(0)",
        "legendFormat": "tokens/session", "refId": "A"
      }],
      "title": "📊 Tokens Salvos / Sessão",
      "type": "stat"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 12 },
      "id": 300,
      "title": "📈 Uso — Atividade Real",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false, "axisColorMode": "text", "axisLabel": "ativações",
            "axisPlacement": "auto", "barAlignment": 0, "drawStyle": "line",
            "fillOpacity": 15, "gradientMode": "scheme",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "smooth", "lineWidth": 2, "pointSize": 5,
            "scaleDistribution": { "type": "linear" }, "showPoints": "never",
            "spanNulls": false, "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "id": 20,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "orbit:activations_total:prod or vector(0)",
        "legendFormat": "activations {{mode}}",
        "refId": "A"
      }],
      "title": "⚡ Ativações (prod)",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false, "axisColorMode": "text", "axisLabel": "sessões",
            "axisPlacement": "auto", "barAlignment": 0, "drawStyle": "line",
            "fillOpacity": 10, "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "smooth", "lineWidth": 2, "pointSize": 5,
            "scaleDistribution": { "type": "linear" }, "showPoints": "never",
            "spanNulls": false, "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "sem ativação" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "light-orange" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "id": 21,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "orbit:sessions_total:prod or vector(0)",
          "legendFormat": "total", "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "orbit:sessions_with_activation:prod or vector(0)",
          "legendFormat": "com ativação", "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "orbit:sessions_without_activation:prod or vector(0)",
          "legendFormat": "sem ativação", "refId": "C"
        }
      ],
      "title": "👥 Sessões (prod)",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false, "axisColorMode": "text", "axisLabel": "tokens/s",
            "axisPlacement": "auto", "barAlignment": 0, "drawStyle": "line",
            "fillOpacity": 25, "gradientMode": "scheme",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "smooth", "lineWidth": 2, "pointSize": 5,
            "scaleDistribution": { "type": "linear" }, "showPoints": "never",
            "spanNulls": false, "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 21 },
      "id": 22,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "rate(orbit:tokens_saved_total:prod[5m]) or vector(0)",
        "legendFormat": "tokens saved/s", "refId": "A"
      }],
      "title": "🪙 Tokens Economizados — Taxa (5m)",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 },
      "id": 400,
      "title": "🚨 Risco — Algo Errado?",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": {
            "axisCenteredZero": false, "axisColorMode": "text", "axisLabel": "failures",
            "axisPlacement": "auto", "barAlignment": 0, "drawStyle": "line",
            "fillOpacity": 20, "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "smooth", "lineWidth": 2, "pointSize": 5,
            "scaleDistribution": { "type": "linear" }, "showPoints": "never",
            "spanNulls": false, "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line+area" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 30 },
