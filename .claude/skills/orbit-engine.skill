name: orbit-engine
description: Fail-closed governance for PromQL, metrics isolation, and token efficiency enforcement.

activation:
  auto: true
  triggers:
    - analyze cost
    - high token usage
    - inefficient session
    - metrics analysis
    - grafana query
    - promql
    - observability
    - performance issue

core_rules:
  - Always enforce fail-closed behavior
  - Never allow raw metrics (orbit_skill_*)
  - Only allow recording rules (orbit:*)
  - Reject empty or ambiguous queries
  - Use strict validation when possible

governance:
  promql:
    allowed:
      - orbit:*
      - orbit_seed_mode
      - orbit_tracking_up
      - orbit_instance_id
      - orbit_last_event_timestamp
    forbidden:
      - orbit_skill_*
      - any raw metric without env isolation
    strict_mode:
      - reject unknown orbit_*
      - reject typos
      - reject non-allowlisted metrics

gateway:
  required: true
  endpoint: http://localhost:9091
  behavior:
    - validate query before execution
    - block invalid queries (400)
    - fail-closed on upstream errors (503)
    - log all violations

diagnostic_output:
  format:
    - DIAGNOSTIC
    - ACTIONS
    - DO_NOT_DO_NOW
  rules:
    - be specific
    - prioritize impact
    - avoid generic advice

modes:
  auto:
    description: Applies fixes automatically when safe
  suggest:
    description: Suggests actions without executing
  off:
    description: Only observes

constraints:
  - No overengineering
  - No speculative suggestions
  - Only actionable steps
  - Must be testable or executable

security:
  - fail_closed_required: true
  - log_violations: true
  - no_silent_fallback: true
